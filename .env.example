# ⚠️ DEPRECATED: This .env format is deprecated!
# 
# Please use config.yml instead for better multi-server support.
# See config.yml.example for the recommended format.
#
# To migrate to YAML:
# 1. Copy: cp config.yml.example ~/.jama/config.yml
# 2. Edit ~/.jama/config.yml with your credentials
# 3. Delete this .env file
#
# This format is maintained only for backward compatibility.
# ================================================================

# Jama API Configuration (Legacy Single-Server Format)
# 
# NOTE: This format is deprecated for multi-server setups.
# Consider using config.yml for better multi-server support.
# See config.yml.example for the recommended format.

JAMA_URL=https://your-jama-instance.com

# Option 1: OAuth Client Credentials (Recommended)
JAMA_OAUTH=true
JAMA_CLIENT_ID=your_client_id
JAMA_CLIENT_SECRET=your_client_secret

# Option 2: API Token Authentication
# JAMA_API_KEY=your_api_token

# Option 3: Username/Password Authentication
# JAMA_USERNAME=your_username
# JAMA_PASSWORD=your_password

# MCP Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
